# Porta HTTP (health check)
PORT=3010

# URL do Web App do Google Apps Script (publicado como "Qualquer pessoa" ou com token)
# Ex.: https://script.google.com/macros/s/XXXX/exec
APPS_SCRIPT_URL=

# Opcional: se o Apps Script validar cabeçalho X-Bot-Token
# APPS_SCRIPT_TOKEN=

# Palavras que disparam o bot (minúsculas). Várias separadas por vírgula.
BOT_TRIGGERS=ADNY

# Opcional: só responder em grupos listados (JID completo, ex. 120363...@g.us). Vários: vírgula.
# ALLOWED_GROUP_IDS=

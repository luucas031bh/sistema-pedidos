# Porta HTTP (health check)
PORT=3010

# URL do Web App do Google Apps Script
APPS_SCRIPT_URL=

# Opcional: se o Apps Script validar cabeçalho X-Bot-Token
# APPS_SCRIPT_TOKEN=

# Palavras que disparam o bot (minúsculas). Várias: vírgula.
BOT_TRIGGERS=ADNY

# Opcional: só responder nesses grupos (JID, vírgula)
# ALLOWED_GROUP_IDS=

# Opcional: Google AI Studio — linguagem natural (Gemini interpreta a pergunta e só dispara consultas GET)
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# Modelo (padrão no código: gemini-2.5-flash). Outros: gemini-2.5-flash-lite, gemini-flash-latest
# Lista e deprecações: https://ai.google.dev/gemini-api/docs/deprecations
# GEMINI_MODEL=gemini-2.5-flash
# true (padrão): segunda chamada ao Gemini reescreve a resposta em tom humano (só com dados da planilha).
# false: só o roteador NL + listas formatadas (menos quota).
# GEMINI_ORGANIC_RESPONSES=true

# Contexto para o Gemini (precisão de regras; NÃO substitui dados da planilha)
# Os números vêm sempre do Web App (Apps Script → Google Sheets). O trecho abaixo só ajuda o modelo a alinhar nomes de ações/campos com o Code.gs.
# Caminho absoluto ou relativo ao processo (cwd). Vazio = tenta Code.gs na raiz do monorepo (pai de BOT-tipoCS).
# PROJECT_CONTEXT_PATH=
# Tamanho máximo do trecho enviado ao prompt (padrão 18000).
# PROJECT_CONTEXT_MAX_CHARS=18000

# Porta local do servidor
PORT=3000

# Meta WhatsApp Cloud API (Developer App)
# META_APP_SECRET: do painel do app (App Secret). Se preenchido, o webhook valida X-Hub-Signature-256.
META_APP_SECRET=
META_VERIFY_TOKEN=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
# Opcional (padrão v21.0)
# META_API_VERSION=v21.0

# Grupo(s) permitido(s): IDs exatos do grupo (campo group_id no webhook). Vários: vírgula.
# Vazio = aceita qualquer origem (útil só em teste).
ALLOWED_GROUP_IDS=

# Palavras que disparam o bot (minúsculas/maiúsculas indiferente). Padrão: ADNY
# BOT_TRIGGER_NAMES=ADNY

# Limite de respostas por minuto por chat (grupo ou DM)
# RATE_LIMIT_PER_MIN=20

# Depuração: logar corpo do webhook (1/true)
# LOG_WEBHOOK_BODY=

# URL do Web App do Google Apps Script (somente GET para leitura no bot)
APPS_SCRIPT_URL=

# Opcional: cabeçalho se você proteger o script no servidor
# APPS_SCRIPT_TOKEN=
